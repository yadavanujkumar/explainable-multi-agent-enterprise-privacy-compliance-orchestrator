{
  "name": "privacy-orchestrator-gateway",
  "version": "2.1.0",
  "description": "Enterprise API Gateway for Privacy Compliance Orchestrator – Slack/Teams integration with zero-trust security",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@slack/web-api": "^7.15.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "kafkajs": "^2.2.4",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^29.5.1",
    "@types/node": "^18.16.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"]
  }
}
