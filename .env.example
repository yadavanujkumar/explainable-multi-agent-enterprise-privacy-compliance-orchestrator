# ---------------------------------------------------------------------------
# Explainable Multi-Agent Enterprise Privacy Compliance Orchestrator
# Environment Variables – copy this file to .env and fill in real values
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Shared
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
NODE_ENV=production

# ---------------------------------------------------------------------------
# Agent Engine
# ---------------------------------------------------------------------------
# Kafka broker address (internal Docker network)
KAFKA_BROKER=kafka:29092

# Topics (override defaults if needed)
DATA_TOPIC=enterprise_data_stream
ALERT_TOPIC=compliance_alerts
AUDIT_TOPIC=audit_trail

# Kafka retry configuration
KAFKA_MAX_RETRIES=15
KAFKA_RETRY_BACKOFF_S=5

# Federated Learning
FL_CLIENT_ID=agent-engine-01
FL_SERVER_URL=https://fl-server.internal/api/v1
FL_DP_NOISE_SCALE=0.1

# Health check port for agent engine
HEALTH_PORT=8080

# ---------------------------------------------------------------------------
# API Gateway
# ---------------------------------------------------------------------------
PORT=3000

# Slack
# Bot OAuth token (xoxb-...)
SLACK_BOT_TOKEN=
# Signing secret from Slack App settings (required for signature verification)
SLACK_SIGNING_SECRET=
# Channel to post compliance alerts to
SLACK_CHANNEL_ID=#compliance-alerts

# Microsoft Teams
# Incoming Webhook URL from Teams channel connector
TEAMS_WEBHOOK_URL=

# Remediation Kafka topic
REMEDIATION_TOPIC=remediation_actions
